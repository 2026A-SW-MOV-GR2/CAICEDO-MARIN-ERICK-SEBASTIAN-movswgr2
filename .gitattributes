# Normalize line endings
* text=auto

# Force LF for specific file types
*.kt text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.properties text eol=lf

# Binary files
*.webp binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.keystore binary
